# Backend environment variables for production
# Copy this to .env and fill in the values

PORT=3002

# Redis for BullMQ (Required for background scanning)
REDIS_URL=redis://localhost:6379

# GitHub App Integration
# The URL where your frontend is hosted (e.g. https://hack-jklu.vercel.app)
FRONTEND_URL=https://your-frontend-domain.vercel.app

GITHUB_APP_ID=your_app_id
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_APP_SLUG=your_app_slug
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Polygon / Web3 (Optional for decentralized reports)
ALCHEMY_API_KEY=your_alchemy_key
PRIVATE_KEY=your_wallet_private_key
CONTRACT_ADDRESS=your_contract_address
PINATA_API_KEY=your_pinata_key
PINATA_SECRET_API_KEY=your_pinata_secret
